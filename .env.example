# Next/Auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Local only. In production this must be false or omitted.
AUTH_DEV_MODE="true"

# App policy
APP_ENV="development"
# Public bookings can use any email; this domain is used for the non-blocking warning.
APP_ALLOWED_DOMAIN="azienda.it"
APP_ADMIN_EMAILS="admin@azienda.it"
APP_PUBLIC_ORIGIN="http://localhost:3000"
APP_TIME_ZONE="Europe/Rome"
APP_WAIVER_RECIPIENT_EMAIL="cecilia.faieta@topflysolutions.com"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/padel_topfly?schema=public"

# Microsoft Entra ID login
MICROSOFT_ENTRA_ID_ID="replace-with-client-id"
MICROSOFT_ENTRA_ID_SECRET="replace-with-client-secret"
MICROSOFT_ENTRA_ID_TENANT_ID="replace-with-tenant-id"

# Microsoft Graph mailbox/calendar for the court
MS_GRAPH_TENANT_ID="replace-with-tenant-id"
MS_GRAPH_CLIENT_ID="replace-with-client-id"
MS_GRAPH_CLIENT_SECRET="replace-with-client-secret"
MS_GRAPH_MAILBOX="padel@azienda.it"
