# Env di STAGING. NIENTE secret veri qui dentro: e' solo un esempio.
# Copiare in .env.staging sul server (o in locale) e riempire con valori di prova.
# Lo staging non riceve traffico ne' cron: serve a provare migrazioni e build,
# non a servire utenti reali.

# App policy. Lo staging gira dietro SSH tunnel su http://localhost:8080.
APP_ENV=production
APP_PUBLIC_ORIGIN=http://localhost:8080
APP_ALLOWED_DOMAIN=topflysolutions.com
APP_ADMIN_EMAILS=admin@topflysolutions.com
APP_TIME_ZONE=Europe/Rome
APP_WAIVER_RECIPIENT_EMAIL=padel@topflysolutions.com
# Segreto cron fittizio: lo staging non ha cron, ma l'avvio fail-fast lo pretende.
APP_INTERNAL_CRON_SECRET=staging-dummy-cron-secret

# Auth. In staging conviene il login dev per non dipendere da Entra.
AUTH_DEV_MODE=true
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:8080
AUTH_SECRET=staging-dummy-auth-secret-change-me

# Postgres dedicato allo staging. POSTGRES_PASSWORD e DATABASE_URL devono combaciare.
# Host 'postgres': nome del servizio Compose, non localhost.
POSTGRES_USER=padel
POSTGRES_PASSWORD=staging-dummy-password
POSTGRES_DB=padel_topfly_staging
DATABASE_URL=postgresql://padel:staging-dummy-password@postgres:5432/padel_topfly_staging?schema=public

# Microsoft Graph/Entra: lasciare vuoti in staging. Senza queste, inviti e mail
# non partono, ed e' esattamente cio' che si vuole in un ambiente di prova.
MICROSOFT_ENTRA_ID_ID=
MICROSOFT_ENTRA_ID_SECRET=
MICROSOFT_ENTRA_ID_TENANT_ID=
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_MAILBOX=padel@topflysolutions.com
