{
  "name": "padel-topfly",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "preview:emails": "node scripts/preview-emails.mjs",
    "clean": "node -e \"const fs=require('fs'); for (const path of ['.next','coverage','output/playwright','.playwright-cli']) fs.rmSync(path,{recursive:true,force:true});\"",
    "clean:full": "npm run clean && node -e \"const fs=require('fs'); fs.rmSync('node_modules',{recursive:true,force:true});\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "pngjs": "^7.0.0",
    "prisma": "6.19.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "24.10.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
