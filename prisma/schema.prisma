generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum BookingStatus {
  CONFIRMED
  CANCELED
}

enum OutlookSyncStatus {
  PENDING
  SYNCED
  FAILED
  SKIPPED
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  image       String?
  role        UserRole     @default(USER)
  lastLoginAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bookings    Booking[]    @relation("BookingOrganizer")
  blocks      AdminBlock[] @relation("BlockCreator")
  auditLogs   AuditLog[]   @relation("AuditActor")
}

model Booking {
  id                String            @id @default(cuid())
  start             DateTime
  end               DateTime
  status            BookingStatus     @default(CONFIRMED)
  organizerName     String
  organizerEmail    String
  manageTokenHash   String?
  manageTokenExpiresAt DateTime?
  outlookEventId    String?
  outlookSyncStatus OutlookSyncStatus @default(PENDING)
  outlookSyncError  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organizerId       String?
  organizer         User?             @relation("BookingOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)

  @@index([start, end])
  @@index([organizerEmail, status, end])
  @@index([manageTokenHash])
}

model AdminBlock {
  id          String   @id @default(cuid())
  start       DateTime
  end         DateTime
  reason      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("BlockCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([start, end])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, entityId])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
