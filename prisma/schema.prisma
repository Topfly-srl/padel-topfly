generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING_SIGNATURES
  CONFIRMED
  CANCELED
}

enum OutlookSyncStatus {
  PENDING
  SYNCED
  FAILED
  SKIPPED
}

enum WaiverSignerRole {
  ORGANIZER
  GUEST
}

enum WaiverEmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WaiverSignatureStatus {
  ACTIVE
  CANCELED
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  image       String?
  role        UserRole     @default(USER)
  lastLoginAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bookings    Booking[]    @relation("BookingOrganizer")
  blocks      AdminBlock[] @relation("BlockCreator")
  auditLogs   AuditLog[]   @relation("AuditActor")
}

model Booking {
  id                String            @id @default(cuid())
  start             DateTime
  end               DateTime
  status            BookingStatus     @default(PENDING_SIGNATURES)
  organizerName     String
  organizerEmail    String
  manageTokenHash   String?
  manageTokenExpiresAt DateTime?
  outlookEventId    String?
  outlookSyncStatus OutlookSyncStatus @default(PENDING)
  outlookSyncError  String?
  playerCount       Int               @default(4)
  waiverRevision    Int               @default(1)
  signatureDeadlineAt DateTime?
  signatureWindowStartedAt DateTime?
  signatureReminderSentAt DateTime?
  signatureConfirmedAt DateTime?
  autoCanceledAt    DateTime?
  cancelReason      String?
  guestWaiverTokenHash String?
  guestWaiverTokenExpiresAt DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organizerId       String?
  organizer         User?             @relation("BookingOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  waiverSignatures  WaiverSignature[]

  @@index([start, end])
  @@index([organizerEmail, status, end])
  @@index([manageTokenHash])
  @@index([guestWaiverTokenHash])
  @@index([status, signatureDeadlineAt])
  @@index([status, signatureReminderSentAt])
}

model WaiverSignature {
  id                         String            @id @default(cuid())
  bookingId                  String
  booking                    Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingRevision            Int
  status                     WaiverSignatureStatus @default(ACTIVE)
  signerRole                 WaiverSignerRole
  signerName                 String
  signerEmail                String
  birthDate                  DateTime
  birthPlace                 String
  isAdultConfirmed           Boolean
  privacyAcceptedAt          DateTime
  regulationAcceptedAt       DateTime
  liabilityAcceptedAt        DateTime
  specificApprovalAcceptedAt DateTime
  signatureText              String
  signatureImageBytes        Bytes?
  signatureImageSha256       String?
  signatureImageMimeType     String?
  signedAt                   DateTime          @default(now())
  ipHash                     String?
  userAgentHash              String?
  documentVersion            String
  pdfBytes                   Bytes
  pdfSha256                  String
  emailStatus                WaiverEmailStatus @default(PENDING)
  emailError                 String?
  emailSentAt                DateTime?
  guestEmailStatus           WaiverEmailStatus @default(SKIPPED)
  guestEmailError            String?
  guestEmailSentAt           DateTime?
  signerEmailStatus          WaiverEmailStatus @default(SKIPPED)
  signerEmailError           String?
  signerEmailSentAt          DateTime?
  cancelTokenHash            String?
  cancelTokenExpiresAt       DateTime?
  canceledAt                 DateTime?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  @@index([bookingId, bookingRevision])
  // NB: oltre a questo indice esiste un UNIQUE index PARZIALE
  // "WaiverSignature_active_booking_revision_email_key" su
  // (bookingId, bookingRevision, signerEmail) WHERE status = 'ACTIVE',
  // creato via SQL grezzo (migrations/20260619090000_active_waiver_signature_unique_email).
  // Prisma non sa esprimere indici parziali: NON usare `prisma db push` su questo DB,
  // altrimenti l'indice viene droppato e salta la dedup su cui si appoggia il catch P2002
  // in waiver-service.ts (createWaiverSignature). Usare solo `prisma migrate`.
  @@index([bookingId, bookingRevision, signerEmail])
  @@index([cancelTokenHash])
  @@index([emailStatus])
  @@index([guestEmailStatus])
  @@index([signerEmailStatus])
  @@index([status])
  @@index([signedAt])
}

model AdminBlock {
  id          String   @id @default(cuid())
  start       DateTime
  end         DateTime
  reason      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("BlockCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([start, end])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, entityId])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}
