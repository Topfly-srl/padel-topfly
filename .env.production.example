# Domain / HTTPS.
# Use a plain domain in production. Do not prefix with ":".
# APP_DOMAIN=:80 is only for temporary HTTP-by-IP tests.
APP_DOMAIN=padel.topflysolutions.com

# App policy
APP_ENV=production
APP_PUBLIC_ORIGIN=https://padel.topflysolutions.com
APP_ALLOWED_DOMAIN=topflysolutions.com
APP_ADMIN_EMAILS=antony.buffone@topflysolutions.com
APP_TIME_ZONE=Europe/Rome

# Auth
AUTH_DEV_MODE=false
AUTH_TRUST_HOST=true
AUTH_URL=https://padel.topflysolutions.com
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Local Postgres container. POSTGRES_PASSWORD and DATABASE_URL must match.
POSTGRES_USER=padel
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_DB=padel_topfly
DATABASE_URL=postgresql://padel:replace-with-long-random-password@postgres:5432/padel_topfly?schema=public

# Microsoft Entra ID login for /admin.
MICROSOFT_ENTRA_ID_ID=
MICROSOFT_ENTRA_ID_SECRET=
MICROSOFT_ENTRA_ID_TENANT_ID=

# Microsoft Graph mailbox/calendar for Outlook invites.
# Leave empty until Graph permissions and the field mailbox are ready.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_MAILBOX=
