(padel_security_headers) {
	encode zstd gzip

	header {
		-Server
		-X-Powered-By
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; upgrade-insecure-requests"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}

	request_body {
		max_size 1MB
	}
}

{$APP_DOMAIN} {
	import padel_security_headers

	@token_pages path /manage/* /waiver/* /test/manage/* /test/waiver/*
	header @token_pages Referrer-Policy "no-referrer"

	handle /test* {
		reverse_proxy app_preview:3000 {
			header_up X-Real-IP {remote_host}
		}
	}

	handle {
		reverse_proxy app:3000 {
			header_up X-Real-IP {remote_host}
		}
	}
}
